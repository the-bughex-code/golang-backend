# ===========================================================================
#  Environment template.
#
#  Copy to .env and fill in real values:      cp .env.example .env
#  .env is gitignored. THIS file is committed, and must never contain a secret.
#
#  In production, do not ship a .env file at all. Inject these as real
#  environment variables via your platform (systemd, Kubernetes, Fly, Render).
#  A secret sitting on a production disk is a secret waiting to be read.
# ===========================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=backend

# development | test | production
# Setting this to `production` turns on extra config validation: TLS is
# required for the database, a wildcard CORS origin is rejected, and APP_URL
# may not point at localhost.
APP_ENV=development

# The public address clients reach this application at. Used to build the links
# inside outbound email.
#
# It CANNOT be derived from the incoming request: the Host header is
# attacker-controlled, and trusting it lets someone send your users a
# verification link pointing at their own server. The base URL is
# configuration, not input.
APP_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Durations use Go syntax: 300ms, 10s, 5m, 1h30m.
# ReadTimeout bounds how long one client may take to send its request. Without
# it, a single slow client can hold a connection open forever (Slowloris).
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# How long graceful shutdown waits for in-flight requests before exiting anyway.
SERVER_SHUTDOWN_TIMEOUT=15s

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=backend_app
DB_PASSWORD=replace-me
DB_NAME=backend_dev

# disable | require | verify-ca | verify-full
# `disable` is acceptable only over loopback. Config validation REFUSES to boot
# with `disable` when APP_ENV=production.
DB_SSLMODE=disable

# Pool sizing. Bigger is not better: every Postgres connection is a separate OS
# process on the server. A pool larger than the database can serve just moves
# the queue somewhere you cannot observe it. Measure before raising.
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Minimum 32 characters; the app refuses to start below that. HMAC-SHA256 keys
# shorter than the 256-bit hash output weaken the signature.
#
#   Generate:  openssl rand -base64 48
#
# Anyone holding this value can mint a valid token for ANY user. Rotating it
# invalidates every access token immediately, which is exactly what you want
# after a leak.
JWT_SECRET=replace-me-with-at-least-32-characters

# Verified on every request, so a token minted by staging cannot be replayed
# against production.
JWT_ISSUER=backend

# Access tokens cannot be revoked — that is the price of statelessness. Keep
# the window small. Refresh tokens are stored server-side and CAN be revoked,
# so they may live much longer.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---------------------------------------------------------------------------
# CORS
#
# CORS is enforced by the BROWSER, not by your server. It stops a script on
# evil.com from reading your API's responses using a logged-in user's cookies.
# It offers no protection against curl, Postman, or a mobile app — those never
# send an Origin header and never honour the response.
#
# A Flutter mobile app therefore ignores CORS entirely. Flutter Web does not.
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-Request-Id
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=300

# ---------------------------------------------------------------------------
# Rate limiting (in-process token bucket, keyed by client IP)
#
# RPS is the sustained refill rate. BURST is how many requests may arrive at
# once before throttling begins.
#
# Limitation to know: this counter lives in ONE process's memory. Run three
# instances behind a load balancer and each allows the full rate, so the real
# limit is 3x. Move to Redis when you scale horizontally.
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# A second, much stricter bucket applied only to /api/v1/auth/*.
#
# The general limit stops runaway clients. This one stops credential stuffing.
# At the general rate an attacker gets 864,000 login attempts per IP per day.
# At 0.5/s they get 43,200 — and each costs the server 300ms of bcrypt, which
# is the entire point.
RATE_LIMIT_AUTH_RPS=0.5
RATE_LIMIT_AUTH_BURST=5

# ---------------------------------------------------------------------------
# Email
#
# In development nothing is actually sent: cmd/api/main.go wires a LogMailer,
# which writes each message to the structured log. The verification link appears
# in your terminal. No SMTP server, no API key, and no chance of emailing a real
# person while you test.
#
# To send real mail, replace ONE line in main.go with an SMTP or Postmark
# implementation of services.Mailer. Nothing above it changes.
# ---------------------------------------------------------------------------
MAIL_FROM=no-reply@localhost

# How long a verification link stays usable. 24h is the usual choice: long
# enough that someone reading mail the next morning is not annoyed, short enough
# that a link left in an old inbox stops being an account-takeover vector.
#
# The link is single-use regardless: redeeming it consumes it.
EMAIL_VERIFICATION_TTL=24h

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=debug

# text = human-readable, for your terminal.
# json = one object per line, for log aggregators. Use json in production.
LOG_FORMAT=text
