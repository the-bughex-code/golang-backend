                },
                "meta": {
                    "description": "Meta is an escape hatch for endpoint-specific extras that do not deserve\na top-level field.",
                    "type": "object",
                    "additionalProperties": {}
                },
                "pagination": {
                    "description": "Pagination is present only on list endpoints.",
                    "allOf": [
                        {
                            "$ref": "#/definitions/response.Pagination"
                        }
                    ]
                },
                "requestId": {
                    "description": "RequestID ties this response to the server logs. When a user reports a\nbug, this string finds the exact request.",
                    "type": "string"
                },
                "success": {
                    "description": "Success is the single field a client should branch on. It is redundant\nwith the HTTP status code on purpose: some proxies and SDKs swallow the\nstatus, and a body that says success=false is impossible to misread.",
                    "type": "boolean"
                },
                "timestamp": {
                    "description": "Timestamp is the server's UTC clock at the moment of the response. Useful\nfor diagnosing client clock skew, which breaks token expiry checks.",
                    "type": "string"
                }
