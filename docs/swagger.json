                    "description": "ExpiresIn is the access token's lifetime in seconds. Clients should\nrefresh slightly before this elapses, rather than waiting for a 401.",
                    "type": "integer"
                },
                "refreshToken": {
                    "description": "RefreshToken is the ONLY time the raw token is ever transmitted. The\nserver stores only its SHA-256 hash and can never show it again.",
                    "type": "string"
                },
                "tokenType": {
                    "description": "TokenType is always \"Bearer\". Sent so the client can build the\nAuthorization header without hardcoding the scheme.",
