                "errors": {
                    "description": "Errors carries per-field validation failures, and is null otherwise.\nThis is the only error detail ever echoed back verbatim.",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/apperrors.FieldError"
                    }
                },
                "message": {
                    "description": "Message is human-readable and safe to display. It is not stable; do not\nbranch on it.",
